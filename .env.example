# ---- Firebase (Realtime Database) ----
# The web config is safe to expose client-side; access is governed by the
# Realtime Database security rules (see database.rules.json), not these keys.
# Sensible defaults for this project are baked into lib/firebase.ts, so the
# ONLY value you really must provide is the database URL.

# REQUIRED. Create the RTDB in the Firebase console (Build → Realtime Database
# → Create Database), then copy its URL here. Region-dependent, e.g.:
#   https://paxgon-castrol-app-launch-default-rtdb.firebaseio.com                       (US)
#   https://paxgon-castrol-app-launch-default-rtdb.asia-southeast1.firebasedatabase.app (Singapore)
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# Optional overrides (defaults in lib/firebase.ts already match this project):
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Activation tuning ----
# Aggregate taps to advance the meter 1%. Tiny for testing; ~1100 for 600 people.
# NEXT_PUBLIC_TAPS_PER_PERCENT=0.5
